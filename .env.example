# FUNIT 品牌環境變數設定
# 客戶資料已填入

# ===== 品牌識別 =====
BRAND_NAME=FUNIT

# ===== Gemini API =====
# 使用系統共用的 Gemini API Key（從根目錄 .env 載入）
GEMINI_API_KEY=YOUR_KEY_HERE

# ===== WordPress 整合 =====
WP_SITE_URL=https://test-funit.welcometw.com
WP_USERNAME=test.vin
WP_APP_PASSWORD=YOUR_PASSWORD_HERE

# ===== ChromaDB 路徑 =====
CHROMADB_STYLE_PATH=./data/chromadb_style
CHROMADB_CONTENT_PATH=./data/chromadb_content

# ===== WooCommerce (未使用) =====
# 客戶回報無 WooCommerce
# WOOCOMMERCE_CONSUMER_KEY=
# WOOCOMMERCE_CONSUMER_SECRET=
